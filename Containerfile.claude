# Container image for running Claude Code in a sandboxed environment
# Optimized for Python (uv) and Node.js development.
# Uses ubuntu:25.10 to provide maximum glibc and build toolchain compatibility.
#
# Build:  podman build -t claude-sandbox -f Containerfile.claude .
# Run:    ./claude-container.sh

FROM ubuntu:25.10

ARG USERNAME=devuser
ENV USERNAME=${USERNAME}

ENV DEBIAN_FRONTEND=noninteractive

# --- System tools and Python build dependencies ---
RUN apt-get update && apt-get install -y --no-install-recommends \
    bash coreutils findutils procps \
    git git-lfs \
    curl wget \
    jq \
    zip unzip tar gzip \
    ca-certificates gnupg \
    patch diffutils \
    file less \
    sed gawk \
    # Python build dependencies \
    build-essential libssl-dev zlib1g-dev \
    libbz2-dev libreadline-dev libsqlite3-dev \
    libncursesw5-dev xz-utils tk-dev libxml2-dev \
    libxmlsec1-dev libffi-dev liblzma-dev \
    # Base Python just in case \
    python3 python3-pip python-is-python3 \
    && rm -rf /var/lib/apt/lists/*

# --- GitHub CLI ---
RUN curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg \
      | gpg --dearmor -o /usr/share/keyrings/githubcli-archive-keyring.gpg \
    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" \
      > /etc/apt/sources.list.d/github-cli.list \
    && apt-get update && apt-get install -y gh \
    && rm -rf /var/lib/apt/lists/*

# --- Node.js 24 LTS ---
RUN curl -fsSL https://deb.nodesource.com/setup_24.x | bash - \
    && apt-get install -y nodejs \
    && rm -rf /var/lib/apt/lists/*

COPY setup_user.sh /tmp/setup_user.sh
RUN chmod +x /tmp/setup_user.sh \
    && /tmp/setup_user.sh ${USERNAME} \
    && rm /tmp/setup_user.sh

USER ${USERNAME}
WORKDIR /home/${USERNAME}

# --- Install uv ---
RUN curl -LsSf https://astral.sh/uv/install.sh | env UV_INSTALL_DIR="/home/${USERNAME}/.local/bin" sh
ENV PATH="/home/${USERNAME}/.local/bin:${PATH}"

# --- Claude Code ---
USER root
# The native installer (https://claude.ai/install.sh) runs out of memory (OOM Exit 137)
# during the binary extraction phase in Podman on macOS natively.
# We bypass the shell script wrapper entirely and pull the static binary directly.
RUN ARCH=$(dpkg --print-architecture) && \
    if [ "$ARCH" = "amd64" ]; then CLAUDE_ARCH="linux-x64"; else CLAUDE_ARCH="linux-arm64"; fi && \
    VERSION=$(curl -fsSL https://storage.googleapis.com/claude-code-dist-86c565f3-f756-42ad-8dfa-d59b1c096819/claude-code-releases/latest) && \
    curl -fsSL -o /usr/local/bin/claude "https://storage.googleapis.com/claude-code-dist-86c565f3-f756-42ad-8dfa-d59b1c096819/claude-code-releases/${VERSION}/${CLAUDE_ARCH}/claude" && \
    chmod +x /usr/local/bin/claude
USER ${USERNAME}

COPY --chown=${USERNAME}:${USERNAME} entrypoint.sh /home/${USERNAME}/.entrypoint.sh
RUN chmod +x /home/${USERNAME}/.entrypoint.sh

ENTRYPOINT ["/bin/sh", "-c", "exec /home/$USERNAME/.entrypoint.sh \"$@\"", "--"]
